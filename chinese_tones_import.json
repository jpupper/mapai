    "tono-1": {
      "id": "tono-1",
      "projectId": "mapa-de-herramientas-conceptual-para-aprender-ch",
      "label": "1° Tono",
      "type": "category",
      "info": "Alto y plano, como cantar una nota sostenida. Ej: māma (妈妈) = mamá",
      "connections": {
        "parent": [
          {
            "id": "root",
            "type": "primary"
          }
        ],
        "children": [],
        "secondary": []
      },
      "infoHTML": "<h3>1° Tono — Tono Plano 🟢</h3>\n<table style=\"width:100%;border-collapse:collapse;font-size:14px;\">\n<tr><td style=\"padding:4px 8px;border:1px solid #555;font-weight:bold;\">N°</td><td style=\"padding:4px 8px;border:1px solid #555;\">1</td></tr>\n<tr><td style=\"padding:4px 8px;border:1px solid #555;font-weight:bold;\">Marca</td><td style=\"padding:4px 8px;border:1px solid #555;font-size:24px;\">ā</td></tr>\n<tr><td style=\"padding:4px 8px;border:1px solid #555;font-weight:bold;\">Descripción</td><td style=\"padding:4px 8px;border:1px solid #555;\">Alto y plano, como cantar una nota sostenida</td></tr>\n<tr><td style=\"padding:4px 8px;border:1px solid #555;font-weight:bold;\">Ejemplo</td><td style=\"padding:4px 8px;border:1px solid #555;font-size:20px;\">Mā</td></tr>\n<tr><td style=\"padding:4px 8px;border:1px solid #555;font-weight:bold;\">Pronunciación</td><td style=\"padding:4px 8px;border:1px solid #555;\">Ma (plano, largo)</td></tr>\n<tr><td style=\"padding:4px 8px;border:1px solid #555;font-weight:bold;\">Español</td><td style=\"padding:4px 8px;border:1px solid #555;\">Mamá</td></tr>\n<tr><td style=\"padding:4px 8px;border:1px solid #555;font-weight:bold;\">Frase</td><td style=\"padding:4px 8px;border:1px solid #555;\">māma (妈妈) = mamá</td></tr>\n</table>\n<p style=\"margin-top:10px;color:#aaa;\">🔊 Imaginá una nota de canto sostenida y pareja.</p>"
    },
    "tono-2": {
      "id": "tono-2",
      "projectId": "mapa-de-herramientas-conceptual-para-aprender-ch",
      "label": "2° Tono",
      "type": "category",
      "info": "Sube, como cuando preguntás '¿Ah?'. Ej: má (麻) = cáñamo",
      "connections": {
        "parent": [
          {
            "id": "root",
            "type": "primary"
          }
        ],
        "children": [],
        "secondary": []
      },
      "infoHTML": "<h3>2° Tono — Tono Ascendente 🟡</h3>\n<table style=\"width:100%;border-collapse:collapse;font-size:14px;\">\n<tr><td style=\"padding:4px 8px;border:1px solid #555;font-weight:bold;\">N°</td><td style=\"padding:4px 8px;border:1px solid #555;\">2</td></tr>\n<tr><td style=\"padding:4px 8px;border:1px solid #555;font-weight:bold;\">Marca</td><td style=\"padding:4px 8px;border:1px solid #555;font-size:24px;\">á</td></tr>\n<tr><td style=\"padding:4px 8px;border:1px solid #555;font-weight:bold;\">Descripción</td><td style=\"padding:4px 8px;border:1px solid #555;\">Sube, como cuando preguntás \"¿Ah?\"</td></tr>\n<tr><td style=\"padding:4px 8px;border:1px solid #555;font-weight:bold;\">Ejemplo</td><td style=\"padding:4px 8px;border:1px solid #555;font-size:20px;\">Má</td></tr>\n<tr><td style=\"padding:4px 8px;border:1px solid #555;font-weight:bold;\">Pronunciación</td><td style=\"padding:4px 8px;border:1px solid #555;\">Ma (subiendo)</td></tr>\n<tr><td style=\"padding:4px 8px;border:1px solid #555;font-weight:bold;\">Español</td><td style=\"padding:4px 8px;border:1px solid #555;\">Cáñamo</td></tr>\n<tr><td style=\"padding:4px 8px;border:1px solid #555;font-weight:bold;\">Frase</td><td style=\"padding:4px 8px;border:1px solid #555;\">—</td></tr>\n</table>\n<p style=\"margin-top:10px;color:#aaa;\">🔊 Sube el tono como si preguntaras algo con sorpresa.</p>"
    },
    "tono-3": {
      "id": "tono-3",
      "projectId": "mapa-de-herramientas-conceptual-para-aprender-ch",
      "label": "3° Tono",
      "type": "category",
      "info": "Baja primero y luego sube (forma de U). Ej: mǎ (马) = caballo / Nǐ hǎo",
      "connections": {
        "parent": [
          {
            "id": "root",
            "type": "primary"
          }
        ],
        "children": [],
        "secondary": []
      },
      "infoHTML": "<h3>3° Tono — Tono Baja-Sube 🟠</h3>\n<table style=\"width:100%;border-collapse:collapse;font-size:14px;\">\n<tr><td style=\"padding:4px 8px;border:1px solid #555;font-weight:bold;\">N°</td><td style=\"padding:4px 8px;border:1px solid #555;\">3</td></tr>\n<tr><td style=\"padding:4px 8px;border:1px solid #555;font-weight:bold;\">Marca</td><td style=\"padding:4px 8px;border:1px solid #555;font-size:24px;\">ǎ</td></tr>\n<tr><td style=\"padding:4px 8px;border:1px solid #555;font-weight:bold;\">Descripción</td><td style=\"padding:4px 8px;border:1px solid #555;\">Baja primero y luego sube (forma de U)</td></tr>\n<tr><td style=\"padding:4px 8px;border:1px solid #555;font-weight:bold;\">Ejemplo</td><td style=\"padding:4px 8px;border:1px solid #555;font-size:20px;\">Mǎ</td></tr>\n<tr><td style=\"padding:4px 8px;border:1px solid #555;font-weight:bold;\">Pronunciación</td><td style=\"padding:4px 8px;border:1px solid #555;\">Ma (baja-sube)</td></tr>\n<tr><td style=\"padding:4px 8px;border:1px solid #555;font-weight:bold;\">Español</td><td style=\"padding:4px 8px;border:1px solid #555;\">Caballo</td></tr>\n<tr><td style=\"padding:4px 8px;border:1px solid #555;font-weight:bold;\">Frase</td><td style=\"padding:4px 8px;border:1px solid #555;\">Nǐ hǎo (你好) = ¡Hola!</td></tr>\n</table>\n<p style=\"margin-top:10px;color:#ff9edb;\">⚠️ REGLA: 3° + 3° Tono → el primero se vuelve 2° tono. \"Nǐ hǎo\" → \"Ní hǎo\"</p>"
    },
    "tono-4": {
      "id": "tono-4",
      "projectId": "mapa-de-herramientas-conceptual-para-aprender-ch",
      "label": "4° Tono",
      "type": "category",
      "info": "Cae fuerte, como dando una orden. Ej: mà (骂) = insultar / zàijiàn (再见) = adiós",
      "connections": {
        "parent": [
          {
            "id": "root",
            "type": "primary"
          }
        ],
        "children": [],
        "secondary": []
      },
      "infoHTML": "<h3>4° Tono — Tono Descendente 🔴</h3>\n<table style=\"width:100%;border-collapse:collapse;font-size:14px;\">\n<tr><td style=\"padding:4px 8px;border:1px solid #555;font-weight:bold;\">N°</td><td style=\"padding:4px 8px;border:1px solid #555;\">4</td></tr>\n<tr><td style=\"padding:4px 8px;border:1px solid #555;font-weight:bold;\">Marca</td><td style=\"padding:4px 8px;border:1px solid #555;font-size:24px;\">à</td></tr>\n<tr><td style=\"padding:4px 8px;border:1px solid #555;font-weight:bold;\">Descripción</td><td style=\"padding:4px 8px;border:1px solid #555;\">Cae fuerte, como dando una orden</td></tr>\n<tr><td style=\"padding:4px 8px;border:1px solid #555;font-weight:bold;\">Ejemplo</td><td style=\"padding:4px 8px;border:1px solid #555;font-size:20px;\">Mà</td></tr>\n<tr><td style=\"padding:4px 8px;border:1px solid #555;font-weight:bold;\">Pronunciación</td><td style=\"padding:4px 8px;border:1px solid #555;\">Ma (bajando fuerte)</td></tr>\n<tr><td style=\"padding:4px 8px;border:1px solid #555;font-weight:bold;\">Español</td><td style=\"padding:4px 8px;border:1px solid #555;\">Insultar / Regañar</td></tr>\n<tr><td style=\"padding:4px 8px;border:1px solid #555;font-weight:bold;\">Frase</td><td style=\"padding:4px 8px;border:1px solid #555;\">Zàijiàn (再见) = Adiós</td></tr>\n</table>\n<p style=\"margin-top:10px;color:#aaa;\">🔊 Cortante y enfático, como una exclamación.</p>"
    },
    "tono-neutro": {
      "id": "tono-neutro",
      "projectId": "mapa-de-herramientas-conceptual-para-aprender-ch",
      "label": "Tono Neutro",
      "type": "category",
