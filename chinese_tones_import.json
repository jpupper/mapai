    "regla-3-3": {
      "id": "regla-3-3",
      "projectId": "mapa-de-herramientas-conceptual-para-aprender-ch",
      "label": "Regla 3°+3° Tono",
      "type": "child",
      "info": "Cuando dos 3° tonos van seguidos, el primero se pronuncia como 2° tono. Ej: Nǐ hǎo → se dice 'Ní hǎo'.",
      "infoHTML": "<h3>⚠️ Regla 3° + 3° Tono</h3>\n<p><strong>Regla fundamental:</strong> Cuando dos sílabas en <strong>3° tono</strong> van seguidas, la <strong>primera</strong> se pronuncia como <strong>2° tono</strong> (ascendente).</p>\n<div style=\"background:rgba(255,165,0,0.1);border:1px solid rgba(255,165,0,0.4);border-radius:8px;padding:15px;margin:10px 0;\">\n<p style=\"font-size:22px;margin:0;\">Nǐ hǎo → <strong>Ní hǎo</strong></p>\n<p style=\"margin:5px 0 0 0;color:#aaa;\">(你好) ¡Hola!</p>\n</div>\n<p>El 3° tono original se escribe igual (nǐ) pero se pronuncia como 2° tono (ní).</p>\n<p>Esto pasa naturalmente porque es más fácil de pronunciar.</p>",
      "parentCategory": "reglas",
      "connections": {
        "parent": [
          {
            "id": "reglas",
            "type": "primary"
          }
        ],
        "children": [],
        "secondary": [
          "tono-3"
        ]
      }
    }
