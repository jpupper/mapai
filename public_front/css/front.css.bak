/* ============================================
   MapAI — Frontend Styles (v2.0)
   Tema oscuro espacial, glassmorphism, animaciones
   ============================================ */

/* ===== FONTS (local, no CDN) ===== */
@font-face {
  font-family: 'Outfit';
  src: local('Outfit'), local('Segoe UI'), local('Tahoma');
  font-weight: 400;
}
@font-face {
  font-family: 'Outfit';
  src: local('Outfit SemiBold'), local('Segoe UI Semibold');
  font-weight: 600;
}
@font-face {
  font-family: 'Outfit';
  src: local('Outfit Bold'), local('Segoe UI Bold');
  font-weight: 800;
}

/* ===== RESET & BASE ===== */
html, body {
  margin: 0;
  padding: 0;
  font-family: 'Outfit', ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
  background: #060a12;
  color: #e6edf3;
  overflow-x: hidden;
  scroll-behavior: smooth;
}

*, *::before, *::after {
  box-sizing: border-box;
}

/* ===== CANVAS PARTICLE BACKGROUND ===== */
#particle-canvas {
  position: fixed;
  inset: 0;
  z-index: 0;
  pointer-events: none;
  opacity: 0.7;
}

/* ===== AMBIENT GLOW ORBS ===== */
#glow-orbs {
  position: fixed;
  inset: 0;
  z-index: 0;
  pointer-events: none;
}

#glow-orbs::before,
#glow-orbs::after {
  content: '';
  position: absolute;
  border-radius: 50%;
  filter: blur(80px);
  animation: orbFloat 12s ease-in-out infinite alternate;
}

#glow-orbs::before {
  width: 600px;
  height: 600px;
  top: -10%;
  left: -5%;
  background: radial-gradient(circle, rgba(80, 140, 255, 0.12), transparent 70%);
  animation-delay: 0s;
}

#glow-orbs::after {
  width: 500px;
  height: 500px;
  bottom: -8%;
  right: -5%;
  background: radial-gradient(circle, rgba(140, 60, 255, 0.10), transparent 70%);
  animation-delay: -6s;
}

@keyframes orbFloat {
  0%   { transform: translate(0, 0) scale(1); }
  33%  { transform: translate(30px, -20px) scale(1.1); }
  66%  { transform: translate(-20px, 30px) scale(0.9); }
  100% { transform: translate(15px, -10px) scale(1.05); }
}

/* Orbe central adicional */
#glow-orbs .orb-center {
  position: absolute;
  width: 400px;
  height: 400px;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: radial-gradient(circle, rgba(0, 200, 255, 0.06), transparent 70%);
  filter: blur(60px);
  animation: orbPulse 8s ease-in-out infinite alternate;
}

@keyframes orbPulse {
  0%   { opacity: 0.4; transform: translate(-50%, -50%) scale(0.8); }
  100% { opacity: 0.8; transform: translate(-50%, -50%) scale(1.2); }
}

/* ===== GRID OVERLAY ===== */
#grid-overlay {
  position: fixed;
  inset: 0;
  z-index: 0;
  pointer-events: none;
  background-image:
    linear-gradient(rgba(30, 64, 120, 0.04) 1px, transparent 1px),
    linear-gradient(90deg, rgba(30, 64, 120, 0.04) 1px, transparent 1px);
  background-size: 80px 80px;
  animation: gridShift 20s linear infinite;
}

@keyframes gridShift {
  0%   { transform: translate(0, 0); }
  100% { transform: translate(80px, 80px); }
}

/* ===== SCROLLBAR ===== */
::-webkit-scrollbar { width: 6px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb {
  background: rgba(138, 180, 255, 0.20);
  border-radius: 3px;
}
::-webkit-scrollbar-thumb:hover {
  background: rgba(138, 180, 255, 0.35);
}

/* ===== LINKS ===== */
a {
  color: #8ab4ff;
  text-decoration: none;
  transition: color 0.3s ease;
}
a:hover {
  color: #b8d4ff;
}

/* ===== LAYOUT ===== */
.wrap {
  max-width: 1000px;
  margin: 0 auto;
  padding: 16px;
  position: relative;
  z-index: 1;
}

/* ===== TOPBAR ===== */
.topbar {
  position: sticky;
  top: 0;
  background: rgba(6, 10, 18, 0.75);
  backdrop-filter: blur(16px) saturate(1.4);
  -webkit-backdrop-filter: blur(16px) saturate(1.4);
  border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  z-index: 100;
  animation: slideDown 0.6s cubic-bezier(0.16, 1, 0.3, 1) both;
}

@keyframes slideDown {
  from { opacity: 0; transform: translateY(-20px); }
  to   { opacity: 1; transform: translateY(0); }
}

.topbar .wrap {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
}

.brand {
  display: grid;
  gap: 2px;
  min-width: 0;
  position: relative;
}

.brand-icon {
  width: 32px;
  height: 32px;
  border-radius: 10px;
  background: linear-gradient(135deg, #8ab4ff, #6633cc);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16px;
  font-weight: 800;
  color: #fff;
  flex-shrink: 0;
  animation: brandPulse 3s ease-in-out infinite;
}

@keyframes brandPulse {
  0%, 100% { box-shadow: 0 0 0 0 rgba(138, 180, 255, 0.3); }
  50%      { box-shadow: 0 0 0 8px rgba(138, 180, 255, 0); }
}

.brand-row {
  display: flex;
  align-items: center;
  gap: 10px;
}

.brand-title {
  font-weight: 800;
  font-size: 18px;
  letter-spacing: -0.3px;
  background: linear-gradient(135deg, #e6edf3 0%, #8ab4ff 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.brand-subtitle {
  font-size: 11px;
  color: rgba(230, 237, 243, 0.50);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  letter-spacing: 0.3px;
  text-transform: uppercase;
}

.topnav {
  display: flex;
  align-items: center;
  gap: 8px;
}

.topnav a {
  padding: 6px 12px;
  border-radius: 8px;
  font-size: 13px;
  color: rgba(230, 237, 243, 0.70);
  transition: all 0.25s ease;
  position: relative;
}

.topnav a:hover {
  color: #e6edf3;
  background: rgba(138, 180, 255, 0.08);
}

/* Nav link shimmer */
.topnav a::after {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: 8px;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.04), transparent);
  transform: translateX(-100%);
  transition: none;
}
.topnav a:hover::after {
  transform: translateX(100%);
  transition: transform 0.6s ease;
}

.icon-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 38px;
  height: 38px;
  border-radius: 12px;
  border: 1px solid rgba(255, 255, 255, 0.10);
  background: rgba(255, 255, 255, 0.04);
  color: #e6edf3;
  cursor: pointer;
  position: relative;
  transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
}

.icon-btn:hover {
  background: rgba(138, 180, 255, 0.12);
  border-color: rgba(138, 180, 255, 0.25);
  transform: scale(1.08) translateY(-1px);
  box-shadow: 0 4px 16px rgba(138, 180, 255, 0.10);
}

.icon-btn:active {
  transform: scale(0.92);
}

.icon {
  display: block;
}

.account-badge {
  position: absolute;
  top: -5px;
  right: -5px;
  width: 20px;
  height: 20px;
  border-radius: 999px;
  background: linear-gradient(135deg, #8ab4ff, #6633cc);
  border: 2px solid rgba(6, 10, 18, 0.95);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 10px;
  font-weight: 800;
  box-shadow: 0 2px 10px rgba(138, 180, 255, 0.30);
  animation: badgePop 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
}

@keyframes badgePop {
  from { transform: scale(0); }
  to   { transform: scale(1); }
}

/* ===== CARD BASE ===== */
.card {
  background: rgba(255, 255, 255, 0.02);
  border: 1px solid rgba(255, 255, 255, 0.06);
  border-radius: 20px;
  padding: 24px;
  margin: 20px 0;
  transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  position: relative;
  overflow: hidden;
}

.card::before {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: 20px;
  background: linear-gradient(135deg, transparent 40%, rgba(138, 180, 255, 0.02) 100%);
  opacity: 0;
  transition: opacity 0.5s ease;
  pointer-events: none;
}

.card:hover::before {
  opacity: 1;
}

.card:hover {
  border-color: rgba(138, 180, 255, 0.12);
  box-shadow: 0 8px 40px rgba(0, 0, 0, 0.25), 0 0 60px rgba(138, 180, 255, 0.03);
  transform: translateY(-2px);
}

h1, h2, h3 {
  margin: 0 0 10px 0;
  letter-spacing: -0.02em;
}

h2 {
  font-size: 22px;
}

.muted {
  margin: 0 0 12px 0;
  color: rgba(230, 237, 243, 0.55);
  line-height: 1.5;
}

/* ===== HERO ===== */
.hero {
  display: grid;
  grid-template-columns: 1.4fr 1fr;
  gap: 20px;
  margin-top: 32px;
  margin-bottom: 32px;
  min-height: 70vh;
  align-items: center;
}

.hero-card {
  position: relative;
  overflow: hidden;
  background: radial-gradient(800px 400px at 20% 0%, rgba(80, 140, 255, 0.15), transparent 60%),
              radial-gradient(600px 400px at 80% 0%, rgba(140, 60, 255, 0.10), transparent 60%),
              rgba(255, 255, 255, 0.02);
  border: 1px solid rgba(255, 255, 255, 0.06);
  border-radius: 24px;
  padding: 36px 28px;
  animation: heroEntrance 0.9s cubic-bezier(0.16, 1, 0.3, 1) 0.1s both;
  perspective: 1000px;
}

@keyframes heroEntrance {
  from { opacity: 0; transform: translateY(40px) scale(0.97); }
  to   { opacity: 1; transform: translateY(0) scale(1); }
}

/* Animated gradient border */
.hero-card::before {
  content: '';
  position: absolute;
  inset: -1px;
  border-radius: 24px;
  padding: 1px;
  background: conic-gradient(
    from 0deg at 50% 50%,
    transparent 0deg,
    rgba(138, 180, 255, 0.10) 60deg,
    transparent 120deg,
    rgba(140, 60, 255, 0.10) 180deg,
    transparent 240deg,
    rgba(0, 200, 255, 0.08) 300deg,
    transparent 360deg
  );
  -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
  -webkit-mask-composite: xor;
  mask-composite: exclude;
  animation: borderSpin 8s linear infinite;
  pointer-events: none;
}

@keyframes borderSpin {
  from { transform: rotate(0deg); }
  to   { transform: rotate(360deg); }
}

.hero-card::after {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: 24px;
  background: radial-gradient(600px 300px at var(--mouse-x, 0.5) var(--mouse-y, 0.5), rgba(138, 180, 255, 0.04), transparent 60%);
  opacity: 0;
  transition: opacity 0.4s ease;
  pointer-events: none;
}

.hero-card:hover::after {
  opacity: 1;
}

.hero-eyebrow {
  font-size: 11px;
  color: rgba(230, 237, 243, 0.50);
  letter-spacing: 2px;
  text-transform: uppercase;
  margin-bottom: 14px;
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  gap: 8px;
}

.hero-eyebrow::before {
  content: '';
  display: inline-block;
  width: 20px;
  height: 1px;
  background: linear-gradient(90deg, #8ab4ff, transparent);
}

.hero-title {
  margin: 0;
  font-size: 44px;
  line-height: 1.04;
  letter-spacing: -1.2px;
  background: linear-gradient(135deg, #ffffff 0%, #8ab4ff 45%, #b480ff 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  position: relative;
  z-index: 1;
  animation: titleReveal 1.2s cubic-bezier(0.16, 1, 0.3, 1) 0.3s both;
}

@keyframes titleReveal {
  from { opacity: 0; transform: translateY(20px); filter: blur(4px); }
  to   { opacity: 1; transform: translateY(0); filter: blur(0); }
}

/* Shimmer animation on title */
.hero-title::after {
  content: attr(data-text);
  position: absolute;
  inset: 0;
  background: linear-gradient(
    90deg,
    transparent 0%,
    rgba(255, 255, 255, 0.12) 25%,
    rgba(138, 180, 255, 0.20) 50%,
    rgba(255, 255, 255, 0.12) 75%,
    transparent 100%
  );
  background-size: 200% 100%;
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  animation: shimmer 4s ease-in-out infinite;
  pointer-events: none;
}

@keyframes shimmer {
  0%   { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

.hero-subtitle {
  margin: 16px 0 0 0;
  font-size: 16px;
  color: rgba(230, 237, 243, 0.65);
  max-width: 54ch;
  line-height: 1.65;
  position: relative;
  z-index: 1;
  animation: fadeUp 0.8s ease-out 0.5s both;
}

/* Decorative floating elements */
.hero-deco {
  position: absolute;
  border-radius: 50%;
  border: 1px solid rgba(138, 180, 255, 0.08);
  pointer-events: none;
  animation: decoFloat 8s ease-in-out infinite;
}

.hero-deco-1 {
  width: 60px; height: 60px;
  top: 10%; right: 8%;
  animation-delay: 0s;
}

.hero-deco-2 {
  width: 30px; height: 30px;
  bottom: 15%; right: 20%;
  animation-delay: -3s;
  border-color: rgba(140, 60, 255, 0.10);
}

.hero-deco-3 {
  width: 16px; height: 16px;
  top: 40%; right: 30%;
  animation-delay: -6s;
  background: rgba(0, 200, 255, 0.06);
  border: none;
}

@keyframes decoFloat {
  0%, 100% { transform: translateY(0) rotate(0deg); }
  50%      { transform: translateY(-15px) rotate(10deg); }
}

.hero-cta {
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
  margin-top: 24px;
  position: relative;
  z-index: 1;
  animation: fadeUp 0.8s ease-out 0.6s both;
}

/* ===== BUTTONS ===== */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  border: 1px solid rgba(255, 255, 255, 0.10);
  background: rgba(255, 255, 255, 0.04);
  color: #e6edf3;
  padding: 12px 22px;
  border-radius: 12px;
  cursor: pointer;
  font-size: 14px;
  font-weight: 600;
  font-family: inherit;
  transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  position: relative;
  overflow: hidden;
  white-space: nowrap;
}

/* Ripple effect container */
.btn::after {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: 12px;
  background: linear-gradient(135deg, transparent 40%, rgba(255, 255, 255, 0.03) 100%);
  pointer-events: none;
}

.btn:hover {
  transform: translateY(-2px);
}

.btn:active {
  transform: scale(0.96);
}

/* Ripple on click (JS will add animation) */
.btn .ripple {
  position: absolute;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.15);
  transform: scale(0);
  animation: rippleEffect 0.6s ease-out forwards;
  pointer-events: none;
}

@keyframes rippleEffect {
  to { transform: scale(4); opacity: 0; }
}

.btn.primary {
  background: linear-gradient(135deg, rgba(138, 180, 255, 0.18), rgba(100, 60, 255, 0.12));
  border-color: rgba(138, 180, 255, 0.25);
  box-shadow: 0 2px 16px rgba(138, 180, 255, 0.06);
}

.btn.primary:hover {
  box-shadow: 0 6px 28px rgba(138, 180, 255, 0.15);
  border-color: rgba(138, 180, 255, 0.40);
  background: linear-gradient(135deg, rgba(138, 180, 255, 0.25), rgba(100, 60, 255, 0.18));
}

.btn.primary:active {
  box-shadow: 0 2px 8px rgba(138, 180, 255, 0.08);
}

.btn.secondary:hover {
  background: rgba(255, 255, 255, 0.07);
  border-color: rgba(255, 255, 255, 0.18);
}

/* ===== HERO STATS ===== */
.hero-stats {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10px;
  margin-top: 28px;
  position: relative;
  z-index: 1;
}

.stat {
  border: 1px solid rgba(255, 255, 255, 0.06);
  background: rgba(0, 0, 0, 0.30);
  border-radius: 16px;
  padding: 16px 14px;
  transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  animation: statEntrance 0.6s ease-out both;
  position: relative;
  overflow: hidden;
}

.stat:nth-child(1) { animation-delay: 0.4s; }
.stat:nth-child(2) { animation-delay: 0.5s; }
.stat:nth-child(3) { animation-delay: 0.6s; }

@keyframes statEntrance {
  from { opacity: 0; transform: translateY(30px) scale(0.95); }
  to   { opacity: 1; transform: translateY(0) scale(1); }
}

.stat::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 2px;
  opacity: 0;
  transition: opacity 0.4s ease;
}

.stat:nth-child(1)::before {
  background: linear-gradient(90deg, transparent, #8ab4ff, transparent);
}
.stat:nth-child(2)::before {
  background: linear-gradient(90deg, transparent, #b480ff, transparent);
}
.stat:nth-child(3)::before {
  background: linear-gradient(90deg, transparent, #00c8ff, transparent);
}

.stat:hover::before {
  opacity: 1;
}

.stat:hover {
  background: rgba(138, 180, 255, 0.05);
  border-color: rgba(138, 180, 255, 0.15);
  transform: translateY(-4px);
  box-shadow: 0 8px 30px rgba(0, 0, 0, 0.20);
}

.stat-value {
  font-weight: 800;
  font-size: 24px;
  background: linear-gradient(135deg, #8ab4ff, #b480ff);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  position: relative;
  z-index: 1;
}

.stat-label {
  font-size: 12px;
  color: rgba(230, 237, 243, 0.60);
  margin-top: 4px;
  position: relative;
  z-index: 1;
  letter-spacing: 0.2px;
}

/* ===== HERO SIDE (features) ===== */
.hero-side {
  animation: heroEntrance 0.9s cubic-bezier(0.16, 1, 0.3, 1) 0.2s both;
}

.side-card {
  background: rgba(255, 255, 255, 0.02);
  border: 1px solid rgba(255, 255, 255, 0.06);
  border-radius: 24px;
  padding: 28px;
  height: 100%;
  transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  position: relative;
  overflow: hidden;
}

.side-card::before {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: 24px;
  background: linear-gradient(180deg, transparent 60%, rgba(138, 180, 255, 0.02) 100%);
  pointer-events: none;
}

.side-card:hover {
  border-color: rgba(138, 180, 255, 0.10);
  box-shadow: 0 8px 40px rgba(0, 0, 0, 0.15);
  transform: translateY(-2px);
}

.side-title {
  margin: 0 0 18px 0;
  font-size: 18px;
  letter-spacing: -0.3px;
  color: #e6edf3;
  display: flex;
  align-items: center;
  gap: 10px;
}

.side-title::after {
  content: '';
  flex: 1;
  height: 1px;
  background: linear-gradient(90deg, rgba(255,255,255,0.06), transparent);
}

.features {
  display: grid;
  gap: 12px;
}

.feature {
  border: 1px solid rgba(255, 255, 255, 0.05);
  background: rgba(0, 0, 0, 0.20);
  border-radius: 16px;
  padding: 16px;
  transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  animation: featureEntrance 0.6s ease-out both;
  position: relative;
  overflow: hidden;
  cursor: default;
}

.feature:nth-child(1) { animation-delay: 0.3s; }
.feature:nth-child(2) { animation-delay: 0.4s; }
.feature:nth-child(3) { animation-delay: 0.5s; }

@keyframes featureEntrance {
  from { opacity: 0; transform: translateX(-20px); }
  to   { opacity: 1; transform: translateX(0); }
}

.feature::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  width: 3px;
  height: 100%;
  border-radius: 0 3px 3px 0;
  opacity: 0;
  transition: opacity 0.4s ease, transform 0.4s ease;
  transform: scaleY(0.5);
}

.feature:nth-child(1)::before { background: linear-gradient(to bottom, #8ab4ff, #5080e0); }
.feature:nth-child(2)::before { background: linear-gradient(to bottom, #b480ff, #8833cc); }
.feature:nth-child(3)::before { background: linear-gradient(to bottom, #00c8ff, #0088cc); }

.feature:hover {
  background: rgba(138, 180, 255, 0.05);
  border-color: rgba(138, 180, 255, 0.12);
  transform: translateX(6px) translateY(-1px);
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);
}

.feature:hover::before {
  opacity: 1;
  transform: scaleY(1);
}

.feature-icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 32px;
  height: 32px;
  border-radius: 10px;
  margin-bottom: 8px;
  font-size: 16px;
}

.feature:nth-child(1) .feature-icon {
  background: rgba(138, 180, 255, 0.12);
  color: #8ab4ff;
}

.feature:nth-child(2) .feature-icon {
  background: rgba(180, 128, 255, 0.12);
  color: #b480ff;
}

.feature:nth-child(3) .feature-icon {
  background: rgba(0, 200, 255, 0.12);
  color: #00c8ff;
}

.feature-title {
  font-weight: 700;
  margin-bottom: 4px;
  font-size: 14px;
}

.feature-text {
  font-size: 13px;
  color: rgba(230, 237, 243, 0.65);
  line-height: 1.5;
}

.side-note {
  margin-top: 16px;
  font-size: 12px;
  color: rgba(230, 237, 243, 0.50);
  padding: 10px 14px;
  border: 1px dashed rgba(255, 255, 255, 0.04);
  border-radius: 12px;
  background: rgba(0, 0, 0, 0.15);
}

/* ===== SECTION DIVIDER ===== */
.section-divider {
  display: flex;
  align-items: center;
  gap: 16px;
  margin: 40px 0 24px;
  opacity: 0.4;
}

.section-divider::before,
.section-divider::after {
  content: '';
  flex: 1;
  height: 1px;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.06), transparent);
}

.section-divider-icon {
  font-size: 18px;
  animation: dividerPulse 3s ease-in-out infinite;
}

@keyframes dividerPulse {
  0%, 100% { opacity: 0.3; }
  50%      { opacity: 0.8; }
}

/* ===== TABS ===== */
.tabs {
  display: flex;
  gap: 8px;
  margin: 16px 0;
}

.tab {
  border: 1px solid rgba(255, 255, 255, 0.10);
  background: rgba(255, 255, 255, 0.03);
  color: #e6edf3;
  padding: 8px 16px;
  border-radius: 10px;
  cursor: pointer;
  font-family: inherit;
  font-size: 14px;
  transition: all 0.25s ease;
}

.tab:hover {
  background: rgba(138, 180, 255, 0.06);
  border-color: rgba(138, 180, 255, 0.15);
}

.tab.active {
  background: rgba(138, 180, 255, 0.12);
  border-color: rgba(138, 180, 255, 0.25);
  box-shadow: 0 0 16px rgba(138, 180, 255, 0.06);
}

/* ===== FORM ===== */
.form {
  display: grid;
  gap: 12px;
}

label {
  display: grid;
  gap: 6px;
  font-size: 14px;
  color: rgba(230, 237, 243, 0.80);
}

input, textarea {
  width: 100%;
  box-sizing: border-box;
  border: 1px solid rgba(255, 255, 255, 0.08);
  background: rgba(0, 0, 0, 0.25);
  color: #e6edf3;
  border-radius: 10px;
  padding: 11px 14px;
  outline: none;
  font-family: inherit;
  font-size: 14px;
  transition: border-color 0.25s ease, box-shadow 0.25s ease, background 0.25s ease;
}

input:focus, textarea:focus {
  border-color: rgba(138, 180, 255, 0.30);
  box-shadow: 0 0 0 3px rgba(138, 180, 255, 0.06);
  background: rgba(0, 0, 0, 0.35);
}

.input {
  width: 320px;
  max-width: 100%;
}

/* ===== ERROR ===== */
.error {
  color: #ff6b8a;
  font-size: 14px;
}

/* ===== LIST (projects) ===== */
.list {
  display: grid;
  gap: 10px;
}

.section-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12px;
  margin-bottom: 16px;
}

.section-head h2 {
  background: linear-gradient(135deg, #e6edf3, #8ab4ff);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.section-actions {
  display: flex;
  align-items: center;
  gap: 10px;
}

.item {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12px;
  padding: 18px;
  border-radius: 16px;
  border: 1px solid rgba(255, 255, 255, 0.04);
  background: rgba(0, 0, 0, 0.12);
  transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  animation: itemEntrance 0.5s ease-out both;
}

.item:nth-child(1) { animation-delay: 0.05s; }
.item:nth-child(2) { animation-delay: 0.1s; }
.item:nth-child(3) { animation-delay: 0.15s; }

@keyframes itemEntrance {
  from { opacity: 0; transform: translateY(20px); }
  to   { opacity: 1; transform: translateY(0); }
}

.item:hover {
  border-color: rgba(138, 180, 255, 0.10);
  background: rgba(138, 180, 255, 0.03);
  transform: translateX(4px);
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);
}

.item h3 {
  margin: 0 0 4px 0;
  font-size: 16px;
}

.item .meta {
  margin: 0;
  font-size: 13px;
  color: rgba(230, 237, 243, 0.55);
}

.item .desc {
  margin: 8px 0 0 0;
  font-size: 14px;
  color: rgba(230, 237, 243, 0.62);
  white-space: pre-wrap;
  line-height: 1.5;
}

.actions {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
  justify-content: flex-end;
}

/* ===== MODAL ===== */
.modal {
  position: fixed;
  inset: 0;
  z-index: 200;
  display: grid;
  place-items: center;
  padding: 16px;
  animation: fadeIn 0.3s ease-out;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to   { opacity: 1; }
}

.modal-backdrop {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.65);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
}

.modal-panel {
  position: relative;
  width: min(460px, 100%);
  background: rgba(12, 16, 24, 0.96);
  border: 1px solid rgba(255, 255, 255, 0.06);
  border-radius: 24px;
  padding: 24px;
  z-index: 1;
  animation: scaleIn 0.3s cubic-bezier(0.16, 1, 0.3, 1);
}

@keyframes scaleIn {
  from { opacity: 0; transform: scale(0.92) translateY(10px); }
  to   { opacity: 1; transform: scale(1) translateY(0); }
}

.modal-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10px;
  margin-bottom: 16px;
}

.modal-title {
  font-weight: 800;
  font-size: 18px;
  letter-spacing: -0.3px;
}

/* ===== SCROLL ANIMATIONS ===== */
.animate-on-scroll {
  opacity: 0;
  transform: translateY(40px);
  transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1),
              transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
}

.animate-on-scroll.visible {
  opacity: 1;
  transform: translateY(0);
}

/* Scale variant */
.animate-scale {
  opacity: 0;
  transform: scale(0.92);
  transition: opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1),
              transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
}

.animate-scale.visible {
  opacity: 1;
  transform: scale(1);
}

/* Slide left variant */
.animate-slide-left {
  opacity: 0;
  transform: translateX(-30px);
  transition: opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1),
              transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
}

.animate-slide-left.visible {
  opacity: 1;
  transform: translateX(0);
}

/* Slide right variant */
.animate-slide-right {
  opacity: 0;
  transform: translateX(30px);
  transition: opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1),
              transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
}

.animate-slide-right.visible {
  opacity: 1;
  transform: translateX(0);
}

/* ===== LOADING OVERLAY ===== */
#loading-overlay {
  position: fixed;
  inset: 0;
  z-index: 9999;
  background: rgba(6, 10, 18, 0.9);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: opacity 0.6s ease;
  pointer-events: none;
}

.loading-spinner {
  width: 40px;
  height: 40px;
  border: 2px solid rgba(138, 180, 255, 0.15);
  border-top-color: #8ab4ff;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* ===== KEYFRAMES (shared) ===== */
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(20px); }
  to   { opacity: 1; transform: translateY(0); }
}

/* ===== RESPONSIVE ===== */
@media (max-width: 900px) {
  .hero {
    grid-template-columns: 1fr;
    min-height: auto;
  }
  .hero-title {
    font-size: 34px;
  }
  .section-head {
    flex-direction: column;
  }
  .input {
    width: 100%;
  }
  .topnav a:not(:first-child) {
    display: none;
  }
}

@media (max-width: 600px) {
  .hero-title {
    font-size: 28px;
    letter-spacing: -0.5px;
  }
  .hero-stats {
    grid-template-columns: 1fr;
  }
  .brand-subtitle {
    white-space: normal;
  }
  .hero-card {
    padding: 24px 18px;
  }
  .side-card {
    padding: 20px;
  }
  .stat {
    padding: 14px 12px;
  }
  .hero-deco {
    display: none;
  }
}

/* ===== STAGGER CHILDREN (for container with delayed children) ===== */
.stagger-children > * {
  opacity: 0;
  transform: translateY(20px);
  transition: opacity 0.5s ease-out, transform 0.5s ease-out;
}

.stagger-children.visible > * {
  opacity: 1;
  transform: translateY(0);
}

.stagger-children.visible > *:nth-child(1) { transition-delay: 0.05s; }
.stagger-children.visible > *:nth-child(2) { transition-delay: 0.1s; }
.stagger-children.visible > *:nth-child(3) { transition-delay: 0.15s; }
.stagger-children.visible > *:nth-child(4) { transition-delay: 0.2s; }
.stagger-children.visible > *:nth-child(5) { transition-delay: 0.25s; }
