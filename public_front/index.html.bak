<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>MapAI — Mapas de Herramientas</title>
  <link rel="stylesheet" href="css/front.css" />
</head>
<body>

  <!-- Background layers (z-index managed by CSS) -->
  <div id="glow-orbs"><div class="orb-center"></div></div>
  <div id="grid-overlay"></div>

  <!-- Loading overlay -->
  <div id="loading-overlay">
    <div class="loading-spinner"></div>
  </div>

  <header class="topbar">
    <div class="wrap">
      <div class="brand">
        <div class="brand-row">
          <div class="brand-icon">M</div>
          <div>
            <div class="brand-title">MapAI</div>
            <div class="brand-subtitle">Mapas interactivos de herramientas</div>
          </div>
        </div>
      </div>
      <nav class="topnav">
        <a id="link-diploia" href="#">DiploIA</a>
        <a id="link-profile" href="#">Mi perfil</a>
        <button id="btn-account" class="icon-btn" type="button" aria-label="Cuenta">
          <span id="account-badge" class="account-badge" style="display:none;"></span>
          <svg id="account-icon" class="icon" width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M12 12a4.5 4.5 0 1 0-4.5-4.5A4.5 4.5 0 0 0 12 12Z" stroke="currentColor" stroke-width="1.8"/>
            <path d="M4 20.2c1.7-3.5 4.7-5.2 8-5.2s6.3 1.7 8 5.2" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
          </svg>
        </button>
      </nav>
    </div>
  </header>

  <main class="wrap">
    <section class="hero">
      <div class="hero-card">
        <div class="hero-deco hero-deco-1"></div>
        <div class="hero-deco hero-deco-2"></div>
        <div class="hero-deco hero-deco-3"></div>
        <div class="hero-eyebrow">Plataforma colaborativa</div>
        <h1 class="hero-title" data-text="Cre&aacute; y compart&iacute; tu mapa de herramientas">Creá y compartí tu mapa de herramientas</h1>
        <p class="hero-subtitle">
          Organizá tecnologías, conectá ideas y publicá tu mapa para que otros lo exploren. Ideal para stacks, flujos de trabajo, recursos y aprendizaje.
        </p>
        <div class="hero-cta">
          <button id="btn-cta-create" class="btn primary" type="button">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            </svg>
            Crear mi mapa
          </button>
          <button id="btn-cta-explore" class="btn secondary" type="button">Explorar mapas</button>
        </div>
        <div class="hero-stats">
          <div class="stat">
            <div id="stat-projects" class="stat-value">—</div>
            <div class="stat-label">mapas públicos</div>
          </div>
          <div class="stat">
            <div id="stat-creators" class="stat-value">—</div>
            <div class="stat-label">creadores</div>
          </div>
          <div class="stat">
            <div class="stat-value">2D</div>
            <div class="stat-label">visualización interactiva</div>
          </div>
        </div>
      </div>
      <div class="hero-side">
        <div class="side-card">
          <h2 class="side-title">Qué podés hacer</h2>
          <div class="features">
            <div class="feature">
              <div class="feature-icon">&#9670;</div>
              <div class="feature-title">Crear mapas</div>
              <div class="feature-text">Armá un proyecto, agregá nodos, categorías y conexiones.</div>
            </div>
            <div class="feature">
              <div class="feature-icon">&#9671;</div>
              <div class="feature-title">Compartir</div>
              <div class="feature-text">Publicá tu mapa y pasá un link para que cualquiera lo vea.</div>
            </div>
            <div class="feature">
              <div class="feature-icon">&#9672;</div>
              <div class="feature-title">Explorar</div>
              <div class="feature-text">Buscá herramientas y navegá visualmente tu ecosistema.</div>
            </div>
          </div>
          <div class="side-note">
            Para editar mapas necesitás una cuenta. Para explorar, no.
          </div>
        </div>
      </div>
    </section>

    <div class="section-divider">
      <div class="section-divider-icon">&#9670;</div>
    </div>

    <section class="card animate-scale" id="create-card" style="display:none;">
      <h2>Crear mapas</h2>
      <p class="muted">La creación de mapas se hace desde el panel de administración.</p>
      <div class="hero-cta" style="justify-content:flex-start; flex-wrap:wrap;">
        <button id="btn-go-admin" class="btn primary" type="button">Ir al admin</button>
        <a id="link-profile-cta" class="btn secondary" href="#">Ver mi perfil</a>
      </div>
    </section>

    <section class="card animate-on-scroll" id="explore">
      <div class="section-head">
        <div>
          <h2>Mapas de la comunidad</h2>
          <p class="muted">Explorá lo que otros ya armaron. Podés abrir cualquier mapa sin loguearte.</p>
        </div>
        <div class="section-actions">
          <input id="public-search" class="input" placeholder="Buscar por nombre, autor o descripción" />
        </div>
      </div>
      <div id="public-projects" class="list stagger-children"></div>
    </section>

  </main>

  <div id="auth-modal" class="modal" style="display:none;" role="dialog" aria-modal="true" aria-label="Cuenta">
    <div id="auth-modal-backdrop" class="modal-backdrop"></div>
    <div class="modal-panel">
      <div class="modal-head">
        <div class="modal-title">Cuenta</div>
        <button id="btn-auth-close" class="icon-btn" type="button" aria-label="Cerrar">
          <svg class="icon" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M18 6 6 18M6 6l12 12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          </svg>
        </button>
      </div>

      <div id="auth-logged" style="display:none;">
        <p class="muted" style="margin-top:0;">Sesión iniciada como <strong id="auth-username"></strong>.</p>
        <button id="btn-logout" class="btn secondary" type="button">Salir</button>
      </div>

      <div id="auth-forms">
        <p class="muted" style="margin-top:0;">Registrate o iniciá sesión para crear y editar mapas.</p>
        <div class="tabs">
          <button id="tab-login" class="tab active" type="button">Ingresar</button>
          <button id="tab-register" class="tab" type="button">Crear usuario</button>
        </div>

        <form id="form-login" class="form">
          <label>
            Usuario
            <input id="login-username" autocomplete="username" />
          </label>
          <label>
            Contraseña
            <input id="login-password" type="password" autocomplete="current-password" />
          </label>
          <button class="btn primary" type="submit">Ingresar</button>
          <div id="login-error" class="error" style="display:none;"></div>
        </form>

        <form id="form-register" class="form" style="display:none;">
          <label>
            Usuario
            <input id="register-username" autocomplete="username" />
          </label>
          <label>
            Contraseña
            <input id="register-password" type="password" autocomplete="new-password" />
          </label>
          <label>
            Confirmar contraseña
            <input id="register-password2" type="password" autocomplete="new-password" />
          </label>
          <button class="btn primary" type="submit">Crear usuario</button>
          <div id="register-error" class="error" style="display:none;"></div>
        </form>
      </div>
    </div>
  </div>

  <script src="js/front.js"></script>
  <script src="js/animations.js"></script>
</body>
</html>
